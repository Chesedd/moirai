# Moirai — шаблон переменных окружения.
# Скопируй в .env и заполни значения. Настоящий .env никогда не коммитится.

# --- Telegram ---
# Токен из @BotFather
TELEGRAM_BOT_TOKEN=

# Разрешённые пользователи, через запятую, например: 123456789,987654321
TELEGRAM_ALLOWED_USER_IDS=

# --- Google Drive ---
# Путь внутри контейнера до JSON-ключа service account
GOOGLE_SERVICE_ACCOUNT_PATH=/app/gdrive-sa.json

# ID папки /TelegramPlanner/ в Google Drive (берётся из URL папки)
GOOGLE_DRIVE_FOLDER_ID=

# --- Таймер напоминаний ---
# Дефолтные значения lead_time (минут) до EVENT и начала SLOT
REMIND_LEAD_EVENT_MIN=15
REMIND_LEAD_SLOT_MIN=5

# --- Поллинг артефактов ---
# Как часто бот проверяет outputs/ на обновления, секунд
OUTPUTS_POLL_INTERVAL_SEC=120

# --- Логирование ---
LOG_LEVEL=INFO
