# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
# Опциональный прокси для Bot API (обход блокировок). Пусто — прямое
# подключение. С compose-стеком: TELEGRAM_PROXY_URL=socks5://xray:1080.
TELEGRAM_PROXY_URL=

# Google Drive (используется с подзадачи 3.2)
GDRIVE_FOLDER_ID=
GDRIVE_SERVICE_ACCOUNT_FILE=/secrets/gdrive.json

# Поллинг outputs/ на Drive (секунды)
OUTPUTS_POLL_INTERVAL_SEC=60

# Таймер напоминаний (бот читает schedule.md раз в минуту
# и шлёт напоминания о приближающихся событиях)
REMINDER_CHECK_INTERVAL_SEC=60
REMIND_LEAD_EVENT_MIN=15
REMIND_LEAD_SLOT_MIN=5
